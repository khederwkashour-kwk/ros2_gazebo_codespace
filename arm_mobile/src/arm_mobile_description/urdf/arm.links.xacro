<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

<xacro:property name="arm_base_length" value="0.1"/>
<xacro:property name="arm_base_width" value="0.1"/>
<xacro:property name="arm_base_height" value="0.02"/>
<xacro:property name="arm_base_mass" value="0.5"/>

<xacro:property name="arm_radius" value="0.02"/>
<xacro:property name="arm_length" value="0.3"/>
<xacro:property name="arm_mass" value="0.3"/>

<xacro:macro name="arm" params=" link_name radius length o_xyz o_rpy m color">
    <link name="${link_name}_link">
        <visual>
            <geometry>
                <cylinder radius="${radius}" length="${length}"/>
            </geometry>
            <origin xyz="${o_xyz}" rpy="${o_rpy}"/>
            <material name="${color}"/>
        </visual> 

        <collision>
            <geometry>
                <sphere radius="${radius}"/> 
            </geometry>
            <origin xyz="${o_xyz}" rpy="${o_rpy}"/>
        </collision>
        <!-- 1. تم تصحيح الاسم إلى cylinder_inertia وتم تمرير البرامترات المعرفة في الماكرو بدلاً من x y z -->
        <xacro:cylinder_inertia m="${m}" r="${radius}" h="${length}" o_xyz="${o_xyz}" o_rpy="${o_rpy}" />
    </link>
</xacro:macro>

<xacro:macro name="base" params=" link_name length width height o_xyz o_rpy m color">
    <link name="${link_name}_link">
        <visual>
            <geometry>
                <box size="${length} ${width} ${height}"/>
            </geometry>
            <origin xyz="${o_xyz}" rpy="${o_rpy}"/>
            <material name="${color}"/>
        </visual> 

        <collision>
            <geometry>
                <box size="${length} ${width} ${height}"/>
            </geometry>
            <origin xyz="${o_xyz}" rpy="${o_rpy}"/>
        </collision>
        <!-- 2. تم تمرير o_xyz و o_rpy هنا لحل مشكلة 'x is not defined' -->
        <xacro:rectagle_inertia m="${m}" x="${length}" y="${width}" z="${height}" o_xyz="${o_xyz}" o_rpy="${o_rpy}" />
    </link>
</xacro:macro>

<!-- استدعاء الماكرو لبناء الروابط مع ضبط الإزاحة Z لتبدأ الأذرع من فوق بعضها وليس من المنتصف -->
<xacro:base link_name="arm_base" length="${arm_base_length}" width="${arm_base_width}" height="${arm_base_height}" o_xyz="0.0 0.0 0.0" o_rpy="0.0 0.0 0.0" m="${arm_base_mass}" color="orange"/>
<xacro:arm link_name="forearm" radius="${arm_radius}" length="${arm_length}" o_xyz="0.0 0.0 ${arm_length/2}" o_rpy="0.0 0.0 0.0" m="${arm_mass}" color="yellow"/>
<xacro:arm link_name="hand" radius="${arm_radius}" length="${arm_length}" o_xyz="0.0 0.0 ${arm_length/2}" o_rpy="0.0 0.0 0.0" m="${arm_mass}" color="orange"/>
<joint name="base_armbase" type="fixed">
    <parent link="base_link"/>
    <child link="arm_base_link"/>
    <origin xyz="0 0 0.2" rpy="0 0 0"/>
</joint>



<!-- 3. المفاصل (Joints) وإضافة محور الدوران الإجباري axis -->
<joint name="armbase_forearm" type="revolute">
    <parent link="arm_base_link"/>
    <child link="forearm_link"/>
    <axis xyz="0 1 0"/>
    <limit lower="0" upper="${pi /2}" velocity="100.0" effort="100.0"/>
    <origin xyz="0 0 ${arm_base_height/2 }" rpy="0 0 0"/>
    <dynamics friction="0.3" damping="0.3" />
</joint>
<!-- 
4. تصحيح الاتصال ليصبح بين الساعد واليد (forearm -> hand) بدلاً من تكرار المفصل الأول -->
<joint name="forearm_hand" type="revolute">
    <parent link="forearm_link"/>
    <child link="hand_link"/>
    <axis xyz="0 1 0"/>
    <limit lower="0" upper="${pi /2}" velocity="100.0" effort="100.0"/>
    <origin xyz="0 0 ${arm_length}" rpy="0 0 0"/>
    <dynamics friction="0.3" damping="0.3" />
</joint>

</robot>
