<?xml version="1.0"?>

<robot  xmlns:xacro="http://www.ros.org/wiki/xacro">

<xacro:property name="base_length" value="0.6"/>
<xacro:property name="base_width" value="0.4"/>
<xacro:property name="base_height" value="0.2"/>
<xacro:property name="wheel_radius" value="0.1"/>
<xacro:property name="wheel_length" value="0.05"/>
<xacro:property name="sphere_radius" value="0.05"/>


    <!-- الماكرو المصحح: تم تغيير param إلى params و raduis إلى radius -->
    <xacro:macro name="wheel_func" params="name radius length color x y z r p Y">
        <link name="${name}_wheel_link">
            <visual>
                <geometry>
                    <cylinder radius="${radius}" length="${length}"/>
                </geometry>
                <origin xyz="${x} ${y} ${z}" rpy="${r} ${p} ${Y}"/>
                
            </visual>
             <collision>
              <geometry>
                    <sphere radius="${wheel_radius}"/> 
               <!-- له خط من النقاط المتصلة cylinder له نقطة اتصال واحدة فقط مع الارض ام  sphere من اجل تقليل المحاكاة الفيزيائية في غازيبو لانه لل cylinder بدل من  sphere استخدمنا  -->
              </geometry>
                <origin xyz="${x} ${y} ${z}" rpy="${r} ${p} ${Y}"/>
                
            </collision>
            <xacro:cylinder_inertia m="1.0" r="${radius}" h="${length}"  o_xyz="${x} ${y} ${z}" o_rpy="${r} ${p} ${Y}" />

        </link>
    </xacro:macro>




   
    <link name="base_link">
            <visual>
                <geometry>
                    <box size="${base_length} ${base_width} ${base_height}"/>
                </geometry>
            
            
            <origin xyz="0.0 0.0 ${wheel_radius} " rpy="0.0 0.0 0.0"/>
            </visual>
            <collision>
            <origin xyz="0.0 0.0  ${base_height/2.0} " rpy="0.0 0.0 0.0"/>
              <geometry>
                    <box size="${base_length} ${base_width} ${base_height}"/>
              </geometry>
                
            </collision>
            <xacro:rectagle_inertia m="5.0" x="${base_length}" y="${base_width}" z="${base_height}" o_rpy="0 0 0" o_xyz="0.0 0.0 ${wheel_radius}"/> 
    </link>
    

    <xacro:wheel_func name="left" radius="${wheel_radius}" length="${wheel_length}" color="yellow" x="0.0" y="0.0" z="0.0" r="${pi/2}" p="0.0" Y="0.0" />
    <xacro:wheel_func name="right" radius="${wheel_radius}" length="${wheel_length}" color="blue" x="0.0" y="0.0" z="0.0" r="${pi/2}" p="0.0" Y="0.0" />

        
        
        
    <joint name="base_left" type="continuous">
        <parent link="base_link"/>
        <child link="left_wheel_link"/>
        <origin xyz="${-base_length /4} -0.225 0.0" rpy="0.0 0.0 0.0"/>
        <axis xyz="0.0 1.0 0.0"/>
        
    </joint>
    


        
        
<joint name="base_right" type="continuous">
        <parent link="base_link"/>
        <child link="right_wheel_link"/>
        <origin xyz="${-base_length /4} 0.225 0.0" rpy="0.0 0.0 0.0"/>
        <axis xyz="0.0 1.0 0.0"/>
        
    </joint>
    



<link name="center_wheel_link">
        <visual>
        
    
            <geometry>
            <sphere radius="${sphere_radius}"/>
            <material name="green"/>
            </geometry>
            <origin xyz="0.0 0 0" rpy="1.57 0.0 0.0"/>
        </visual>
         <xacro:sphere_inertia  m="0.5" r="${sphere_radius}" o_xyz="0.0 0 0" o_rpy="1.57 0.0 0.0"/>   
            <collision>

           <geometry>

                    <sphere radius="${sphere_radius}"/>
              </geometry>
            <origin xyz="0.0 0 0" rpy="1.57 0.0 0.0"/>
                
            </collision>
        </link>




        
        
        
    <joint name="base_center" type="fixed">
        <parent link="base_link"/>
        <child link="center_wheel_link"/>
        <origin xyz="${base_length /3} 0 -0.05" rpy="0.0 0.0 0.0"/>
        
        
    </joint>
    

<link name="base_footprint">
    

</link>
<joint name="joint_name" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0.0 0.0 0.05" rpy="0.0 0.0 0.0"/>
</joint>
    
</robot>